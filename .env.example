# 主加密密钥（用于加密存储的真密钥）
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=your-fernet-key-here

# JWT 签名密钥（管理员登录 Token 使用）
# 为空时默认使用 MASTER_KEY；生产环境建议单独生成并设置
JWT_SECRET=your-fernet-key-here

# 数据库路径
DATABASE_URL=sqlite+aiosqlite:///./ai_api_manager.db

# 服务配置
HOST=0.0.0.0
PORT=8000

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
